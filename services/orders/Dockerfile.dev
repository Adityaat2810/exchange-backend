# Development Dockerfile with hot-reload support
FROM golang:1.24-alpine

# Install air for hot-reload (pinned to version compatible with Go 1.24)
RUN go install github.com/air-verse/air@v1.61.7

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY services/orders ./services/orders

ENV PORT=8081
EXPOSE 8081

# Use air for hot-reload in dev
CMD ["air", "-c", "services/orders/.air.toml"]
